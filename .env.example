# frontdoor — environment variables
#
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored; .env.example is the committed template — every secret
# the app touches should appear here so a fresh clone sees the full surface.
#
# See docs/architecture.md §4 for which integration each secret belongs to,
# and docs/implementation-plan.md for which work item first needs it.

# === Vercel KV (Upstash Redis) ===
# Provisioned automatically when you add Vercel KV from the Marketplace.
# After `vercel link`, run: `vercel env pull .env.local` to populate locally.
#   Needed by: #2 (KV setup) and everything downstream.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# === NASA APOD ===
# Free key from https://api.nasa.gov (instant). `DEMO_KEY` works but is
# rate-limited (per-IP, ~30/hr) — fine for local dev, not for prod cron.
#   Needed by: #7 (image source fetchers).
NASA_API_KEY=

# === Resend (signup email) ===
# Sign up at https://resend.com → API Keys → Create API Key.
# Free tier: 3,000/mo, 100/day — covers MVP comfortably.
#   Needed by: #18 (Resend integration), #19 (signup endpoint).
RESEND_API_KEY=

# The verified sending address, e.g. `frontdoor <noreply@frontdoor.app>`.
# Add the domain in Resend, then add the SPF/DKIM DNS records to the registrar.
#   Needed by: #18, #26.
RESEND_FROM_EMAIL=

# === Cron protection ===
# Bearer token Vercel attaches to its cron requests; /api/refresh and
# /api/revalidate must reject anything without it (else they're publicly
# triggerable). Generate with: `openssl rand -hex 32`
#   Needed by: #24 (refresh cron), #25 (revalidate cron).
CRON_SECRET=

# === Cookie signing ===
# Secret used to sign the httpOnly session cookie, so the proxy can verify
# the cookie's userId+slug without a KV round-trip on every load.
# Generate with: `openssl rand -hex 32`
#   Needed by: #20 (auth proxy).
COOKIE_SECRET=

# === Local-dev Resend bypass (#70) ===
# When set AND NODE_ENV !== 'production', POST /api/keys accepts the value
# in the request body as `{ "bootstrap": "<this>" }` to skip Resend entirely
# and return the apiKey + bootstrap URL directly in the response. Used by
# `./fd.sh local user signup <email>` for friction-free local-dev signup.
#
# Production unconditionally rejects the `bootstrap` field — even if this
# var somehow leaked into a prod env, the bypass cannot activate.
#
# Generate with: `openssl rand -hex 16` (any value works; just needs to
# match between this file and what fd.sh sends).
#   Needed by: #70 (local signup bypass) — local dev only.
LOCAL_BOOTSTRAP_KEY=
